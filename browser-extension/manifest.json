{
  "manifest_version": 3,
  "name": "抖音Cookie助手",
  "version": "1.0.0",
  "description": "自动提取抖音Cookie并发送到本地应用",
  "permissions": [
    "activeTab",
    "cookies"
  ],
  "host_permissions": [
    "https://www.douyin.com/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.douyin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
